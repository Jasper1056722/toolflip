---
import Layout from './Layout.astro';
import AdSlot from '../components/AdSlot.astro';

interface Props {
  title: string;
  description: string;
  category: string;
  targetKeyword?: string;
}

const { title, description, category, targetKeyword } = Astro.props;
const seoDescription = targetKeyword ? `${title} — ${description}` : description;
---

<Layout title={title} description={seoDescription}>

  <!-- Compact dark header for tool pages -->
  <div class="bg-slate-950 border-b border-slate-800">
    <div class="max-w-6xl mx-auto px-4 py-4">
      <nav class="text-xs text-slate-500 flex items-center gap-1.5 font-mono" aria-label="Breadcrumb">
        <a href="/" class="hover:text-slate-300 transition-colors">toolflip.dev</a>
        <span class="text-slate-700">/</span>
        <span class="text-slate-600 capitalize">{category}</span>
        <span class="text-slate-700">/</span>
        <span class="text-slate-400">{title.toLowerCase().replace(/ /g, '-')}</span>
      </nav>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="flex gap-8">

      <!-- Main tool area -->
      <div class="flex-1 min-w-0">
        <div class="mb-6">
          <h1 class="text-2xl font-bold text-slate-900 mb-1">{title}</h1>
          <p class="text-sm text-slate-500">{description}</p>
        </div>

        <!-- Tool card wrapper -->
        <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
          <slot />
        </div>

        <div class="my-8">
          <AdSlot size="leaderboard" />
        </div>

        <section class="mt-4">
          <slot name="faq" />
        </section>
      </div>

      <!-- Sidebar ad -->
      <aside class="hidden lg:block w-[300px] flex-shrink-0 pt-[72px]">
        <div class="sticky top-20">
          <AdSlot size="rectangle" />
        </div>
      </aside>

    </div>
  </div>
</Layout>
