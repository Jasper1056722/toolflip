---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
}

const {
  title,
  description = 'Free browser-based tools for developers and designers. No uploads, no servers — everything runs in your browser.',
  canonicalPath = Astro.url.pathname,
} = Astro.props;

const site = 'https://toolflip.dev';
const canonical = `${site}${canonicalPath}`;
const fullTitle = `${title} — ToolFlip`;
const ogImage = `${site}/og.png`;

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ToolFlip',
  url: site,
  description: 'Free browser-based tools for developers and designers. No uploads, no servers.',
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph (link previews in Slack, Discord, social) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="ToolFlip" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Indexing -->
    <meta name="robots" content="index, follow" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <slot name="head" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Privacy-friendly analytics by Plausible -->
    <script is:inline async src="https://plausible.io/js/pa-bekivkxkl_bXz8BPRqAqv.js"></script>
    <script is:inline>
      window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
      plausible.init()
    </script>
  </head>
  <body class="bg-slate-50 text-slate-900 min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
