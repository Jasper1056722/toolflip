---
import ToolLayout from '../../layouts/ToolLayout.astro';
import TextCaseConverter from '../../components/TextCaseConverter';

const faqs = [
  {
    question: 'What is camelCase?',
    answer: 'camelCase joins words with no spaces, capitalising every word except the first. Common in JavaScript variable names.',
  },
  {
    question: 'What is snake_case?',
    answer: 'snake_case replaces spaces with underscores and lowercases everything. Common in Python and database column names.',
  },
  {
    question: 'What is kebab-case?',
    answer: 'kebab-case replaces spaces with hyphens. Used in URLs, CSS class names, and HTML attributes.',
  },
];
---

<ToolLayout
  title="Text Case Converter"
  description="Convert text between camelCase, snake_case, PascalCase, kebab-case, UPPERCASE, and more."
  category="text"
  targetKeyword="text case converter online camelCase snake_case"
  faqs={faqs}
>
  <TextCaseConverter client:load />
</ToolLayout>
