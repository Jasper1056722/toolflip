---
import ToolLayout from '../../layouts/ToolLayout.astro';
import LineSorter from '../../components/LineSorter';

const faqs = [
  {
    question: 'Can I chain multiple operations?',
    answer: 'Yes — each button applies to the current output. Remove duplicates first, then sort, for example.',
  },
  {
    question: 'Is there a line limit?',
    answer: 'No server limit since everything runs in your browser. Large lists (tens of thousands of lines) work fine.',
  },
];
---

<ToolLayout
  title="Line Sorter & Deduplicator"
  description="Sort lines alphabetically, reverse, remove duplicates, trim whitespace, or shuffle. One click per operation."
  category="text"
  targetKeyword="sort lines alphabetically online remove duplicates"
  faqs={faqs}
>
  <LineSorter client:load />
</ToolLayout>
