---
import ToolLayout from '../../layouts/ToolLayout.astro';
import SlugGenerator from '../../components/SlugGenerator';

const faqs = [
  {
    question: 'What is a URL slug?',
    answer: 'A slug is the part of a URL that identifies a page in a human-readable way. For example, in /blog/my-first-post, the slug is my-first-post.',
  },
  {
    question: 'Are accented characters handled?',
    answer: 'Yes. Characters like é, ü, and ñ are converted to their ASCII equivalents before slugifying.',
  },
];
---

<ToolLayout
  title="URL Slug Generator"
  description="Convert any title or phrase into a clean, URL-safe slug. Handles accents, special characters, and spaces."
  category="text"
  targetKeyword="url slug generator online free"
  faqs={faqs}
>
  <SlugGenerator client:load />
</ToolLayout>
