---
import ToolLayout from '../../layouts/ToolLayout.astro';
import CssGradient from '../../components/CssGradient';

const faqs = [
  {
    question: 'What is the difference between linear and radial gradients?',
    answer: 'A linear gradient transitions colors along a straight line at a given angle. A radial gradient radiates outward from a center point in a circle or ellipse.',
  },
  {
    question: 'How many color stops can I use?',
    answer: 'CSS supports unlimited stops; this tool lets you add up to five, which covers nearly all practical designs.',
  },
  {
    question: 'Do CSS gradients affect performance?',
    answer: 'Gradients are rendered by the browser and are far lighter than image files. They also scale perfectly on any screen resolution.',
  },
];
---

<ToolLayout
  title="CSS Gradient Generator"
  description="Build linear and radial CSS gradients visually. Adjust angle and color stops, then copy the CSS with one click."
  category="css"
  targetKeyword="css gradient generator online linear radial"
  faqs={faqs}
>
  <CssGradient client:load />
</ToolLayout>
