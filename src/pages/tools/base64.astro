---
import ToolLayout from '../../layouts/ToolLayout.astro';
import Base64Tool from '../../components/Base64Tool';

const faqs = [
  {
    question: 'What is Base64?',
    answer: 'Base64 is an encoding scheme that converts binary data into ASCII text, making it safe to transmit over text-based protocols like HTTP and email.',
  },
  {
    question: 'Is Base64 encryption?',
    answer: 'No. Base64 is encoding, not encryption. It is easily reversible and provides no security. Do not use it to hide sensitive data.',
  },
];
---

<ToolLayout
  title="Base64 Encoder & Decoder"
  description="Encode text to Base64 or decode Base64 back to plain text. Live two-way conversion in your browser."
  category="data"
  targetKeyword="base64 encode decode online free"
  faqs={faqs}
>
  <Base64Tool client:load />
</ToolLayout>
