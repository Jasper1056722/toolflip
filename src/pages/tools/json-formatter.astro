---
import ToolLayout from '../../layouts/ToolLayout.astro';
import JsonFormatter from '../../components/JsonFormatter';

const faqs = [
  {
    question: 'What does the formatter do?',
    answer: 'It parses your JSON and re-outputs it with consistent 2-space indentation and line breaks, making it human-readable.',
  },
  {
    question: 'What is JSON minification?',
    answer: 'Minification removes all whitespace to make JSON as compact as possible — useful for APIs and storage.',
  },
  {
    question: 'Is my JSON data safe?',
    answer: 'Yes. Everything runs locally in your browser. No data is sent to any server.',
  },
];
---

<ToolLayout
  title="JSON Formatter & Validator"
  description="Prettify, minify, and validate JSON instantly. Runs in your browser — nothing is uploaded."
  category="data"
  targetKeyword="json formatter validator online free"
  faqs={faqs}
>
  <JsonFormatter client:load />
</ToolLayout>
