---
import ToolLayout from '../../layouts/ToolLayout.astro';
import CharacterCounter from '../../components/CharacterCounter';

const faqs = [
  {
    question: "What is Twitter's character limit?",
    answer: '280 characters for standard tweets. URLs always count as 23 characters regardless of length.',
  },
  {
    question: 'What is the ideal meta description length?',
    answer: 'Google truncates meta descriptions at around 160 characters. Aim for 120–155 for best display in search results.',
  },
];
---

<ToolLayout
  title="Character Counter"
  description="Count characters, words, and lines. See live limits for Twitter, LinkedIn, meta descriptions, and more."
  category="text"
  targetKeyword="character counter online words lines twitter limit"
  faqs={faqs}
>
  <CharacterCounter client:load />
</ToolLayout>
