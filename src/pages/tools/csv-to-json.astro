---
import ToolLayout from '../../layouts/ToolLayout.astro';
import CsvToJson from '../../components/CsvToJson';

const faqs = [
  {
    question: 'Is my data uploaded anywhere?',
    answer: 'No. The conversion runs entirely in your browser using JavaScript. Your CSV data never leaves your device.',
  },
  {
    question: 'What CSV format is supported?',
    answer: 'Standard comma-separated values with a header row. Quoted fields are supported. The first row is used as JSON keys.',
  },
  {
    question: 'Can I convert large CSV files?',
    answer: "Yes — since processing is local, there's no server file size limit. Performance depends on your browser, but files up to tens of MB convert fine.",
  },
];
---

<ToolLayout
  title="CSV to JSON Converter"
  description="Paste CSV data and get clean JSON instantly. Free, online, no file upload — runs entirely in your browser."
  category="data"
  targetKeyword="csv to json converter online free"
  faqs={faqs}
>
  <CsvToJson client:load />
</ToolLayout>
