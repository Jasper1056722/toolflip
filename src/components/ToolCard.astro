---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
}

const { title, description, href, icon } = Astro.props;
---

<a
  href={href}
  class="group block bg-white rounded-xl border border-slate-200 p-5 hover:border-indigo-400 hover:shadow-md transition-all"
>
  <div class="text-2xl mb-3">{icon}</div>
  <h3 class="font-semibold text-slate-900 group-hover:text-indigo-600 transition-colors mb-1">
    {title}
  </h3>
  <p class="text-sm text-slate-500 leading-relaxed">{description}</p>
</a>
