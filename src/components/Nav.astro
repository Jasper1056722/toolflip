---
const navLinks = [
  { label: 'Data', href: '/#data' },
  { label: 'SVG', href: '/#svg' },
  { label: 'Text', href: '/#text' },
  { label: 'CSS', href: '/#css' },
];
---

<header class="bg-white border-b border-slate-200 sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-bold text-lg text-indigo-600 hover:text-indigo-700">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
      </svg>
      ToolFlip
    </a>

    <nav class="hidden sm:flex items-center gap-6 text-sm text-slate-600">
      {navLinks.map(link => (
        <a href={link.href} class="hover:text-indigo-600 transition-colors">{link.label}</a>
      ))}
    </nav>
  </div>
</header>
