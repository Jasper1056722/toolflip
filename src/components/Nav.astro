---
const navLinks = [
  { label: 'Data', href: '/#data' },
  { label: 'SVG', href: '/#svg' },
  { label: 'Text', href: '/#text' },
  { label: 'CSS', href: '/#css' },
];
---

<header class="bg-slate-950/90 backdrop-blur-md border-b border-slate-800 sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-semibold text-white hover:text-indigo-400 transition-colors">
      <div class="w-7 h-7 rounded-md bg-indigo-500 flex items-center justify-center">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
        </svg>
      </div>
      ToolFlip
    </a>

    <nav class="hidden sm:flex items-center gap-1 text-sm">
      {navLinks.map(link => (
        <a href={link.href} class="px-3 py-1.5 rounded-md text-slate-400 hover:text-white hover:bg-slate-800 transition-colors">
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>
